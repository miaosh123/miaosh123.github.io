itle span, .layui-layer-title { text-overflow: ellipsis; white-space: nowra=
p; }

html #layui_layer_skinlayercss { display: none; position: absolute; width: =
1989px; }

.layui-layer, .layui-layer-shade { position: fixed; pointer-events: auto; }

.layui-layer-shade { top: 0px; left: 0px; width: 100%; height: 100%; }

.layui-layer { top: 150px; left: 0px; margin: 0px; padding: 0px; background=
-color: rgb(255, 255, 255); background-clip: content; box-shadow: rgba(0, 0=
, 0, 0.3) 1px 1px 50px; border-radius: 2px; animation-fill-mode: both; anim=
ation-duration: 0.3s; }

.layui-layer-close { position: absolute; }

.layui-layer-content { position: relative; }

.layui-layer-border { border: 1px solid rgba(0, 0, 0, 0.3); box-shadow: rgb=
a(0, 0, 0, 0.2) 1px 1px 5px; }

.layui-layer-moves { position: absolute; border: 3px solid rgba(0, 0, 0, 0.=
5); cursor: move; background-color: rgba(255, 255, 255, 0.3); }

.layui-layer-load { background: url("default/loading-0.gif") center center =
no-repeat rgb(255, 255, 255); }

.layui-layer-ico { background: url("default/icon.png") no-repeat; }

.layui-layer-btn a, .layui-layer-dialog .layui-layer-ico, .layui-layer-setw=
in a { display: inline-block; vertical-align: top; }

@-webkit-keyframes bounceIn {=20
  0% { opacity: 0; transform: scale(0.5); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes bounceIn {=20
  0% { opacity: 0; transform: scale(0.5); }
  100% { opacity: 1; transform: scale(1); }
}

.layer-anim { animation-name: bounceIn; }

@-webkit-keyframes bounceOut {=20
  100% { opacity: 0; transform: scale(0.7); }
  30% { transform: scale(1.03); }
  0% { transform: scale(1); }
}

@keyframes bounceOut {=20
  100% { opacity: 0; transform: scale(0.7); }
  30% { transform: scale(1.03); }
  0% { transform: scale(1); }
}

.layer-anim-close { animation-name: bounceOut; animation-duration: 0.2s; }

